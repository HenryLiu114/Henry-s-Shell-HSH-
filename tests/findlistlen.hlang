/defun listlen /[/var l; /var x] /[
    /if /{/null l} 
        /{/print /usevar x}
        /{
            /split l -,
            /cdr l,
            /var x /add usevar x 1,
            /desplit l -,
            /newlist l1,
            /consvar l1 l,
            /consvar l1 x,
            /usefun listlen l1
        }
    /endif
]
/endfun.
/usefun listlen (1-2-3-4-5-6-7-8 0).