/var x 5.
/var y 10.
/var z 11.
/var a /concat "Hi Mom" " lol: ".
/var b "Hi Dad".
/if /{/and /lteq /usevar x /usevar y /lteq /usevar x /usevar y}
    /if /{/lteq /usevar y /usevar z}
        /{print /concat /usevar a /add /usevar x /usevar y}
        /{print /usevar b}
        /endif
    /print no
    /endif.